{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about application users and their roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["ADMIN", "COOK", "STUDENT"] },
        "displayName": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "Dishes available in the restaurant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "green": { "type": "boolean" },
        "allergens": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders for food.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "completed", "cancelled"] },
        "slot": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "StockAlert": {
      "title": "Stock Alert",
      "description": "Alerts for low inventory.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "name": { "type": "string" },
        "currentStock": { "type": "integer" },
        "minStock": { "type": "integer" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Customer comments and ratings for menu items.",
      "type": "object",
      "properties": {
        "menuId": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["menuId", "userId", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and RBAC data."
    },
    "/menus/{menuId}": {
      "schema": "MenuItem",
      "description": "Main restaurant menu."
    },
    "/menus/{menuId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific menu item."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history and active queue."
    },
    "/stockAlerts/{alertId}": {
      "schema": "StockAlert",
      "description": "Real-time stock monitoring alerts."
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Dishes
    match /dishes/{dishId} {
      allow read: if true;
      allow write: if isSignedIn(); // In a real app, restrict to admins
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || true); // true for staff/kitchen
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn(); // restrict based on role
    }

    // Tables
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Analytics
    match /analytics/daily {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    function isOneOfRoles(roles) {
      return isSignedIn() && getUserRole() in roles;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users
    match /users/{userId} {
      // Students can only read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isOneOfRoles(['MANAGER', 'SUPER_ADMIN']);
      // Role can NEVER be changed by the user itself (Immortal Field Rule)
      allow create: if isSignedIn() && request.resource.data.role == 'STUDENT'; 
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
    }

    // Dishes
    match /dishes/{dishId} {
      allow read: if true;
      allow write: if isOneOfRoles(['MANAGER', 'SUPER_ADMIN', 'COOK']);
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isOneOfRoles(['COOK', 'SERVER', 'MANAGER', 'SUPER_ADMIN'])
      );
      allow create: if hasRole('STUDENT') && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled') ||
        (isOneOfRoles(['COOK', 'SERVER']) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }

    // Tables
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Analytics
    match /analytics/daily {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
